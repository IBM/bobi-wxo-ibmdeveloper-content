# =============================================================================
# IBM i MCP Server — HTTP Deployment Configuration
# Deploy this folder to: /home/<your-ibmi-user>/samco-mcp/ on the IBM i
#
# RENAME this file to .env before use:
#   cp ibmi-deploy.env .env
# =============================================================================

# IBM i / Mapepire — use localhost since this runs ON the IBM i itself
DB2i_HOST=localhost
DB2i_PORT=8076
DB2i_USER=YOUR_IBMI_USERNAME
DB2i_PASS=YOUR_IBMI_PASSWORD
DB2i_IGNORE_UNAUTHORIZED=true

# MCP Server — HTTP mode, open to all interfaces so Orchestrate can reach it
MCP_TRANSPORT_TYPE=http
MCP_HTTP_PORT=3010
MCP_HTTP_HOST=0.0.0.0
MCP_LOG_LEVEL=info
MCP_AUTH_MODE=none

# Tools YAML path (relative to this directory)
TOOLS_YAML_PATH=./retail-services.yaml

# Session + Rate Limiting
MCP_SESSION_MODE=stateless
MCP_RATE_LIMIT_ENABLED=false
