# =============================================================================
#  SAMCO Retail — Workflow Configuration
#  workflow.env
#
#  Copy this file:
#    cp workflow.env.example workflow.env
#  Fill in your values. NEVER commit workflow.env to git.
# =============================================================================

# ── IBM i System ──────────────────────────────────────────────────────────────
IBMI_HOST=YOUR_IBMI_HOSTNAME_OR_IP   # IBM i hostname or IP
IBMI_USER=YOUR_IBMI_USERNAME         # SSH username
# SSH password is read interactively (not stored here for security)
# To avoid prompts: set up SSH key auth with ssh-copy-id

# MCP Server port on IBM i (must match ibmi-deploy/ibmi-deploy.env MCP_HTTP_PORT)
IBMI_MCP_PORT=3011

# ── Orchestrate ───────────────────────────────────────────────────────────────
# Path to .venv containing ibm-watsonx-orchestrate ADK
VENV_PATH=/path/to/your/.venv

# Orchestrate toolkit and agent names (must match agent/samco-retail-agent.yaml)
TOOLKIT_NAME=samco-ibmi-mcp
AGENT_NAME=samco_retail_agent

# ── ngrok ─────────────────────────────────────────────────────────────────────
# Leave NGROK_STATIC_URL blank to let the workflow auto-capture the URL.
# Set it ONLY if you have a paid ngrok static domain and use --skip-ngrok.
NGROK_STATIC_URL=

# ── Optional overrides ────────────────────────────────────────────────────────
# Uncomment to override the IBM i deploy directory (default: /home/<user>/samco-mcp)
# IBMI_DEPLOY_DIR=/home/YOUR_IBMI_USERNAME/samco-mcp
