# =============================================================================
# SAMCO Retail — IBM i MCP Server Configuration
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# IBM i / Mapepire Connection
# The MCP server connects to Mapepire (WebSocket SQL gateway) on the IBM i.
# Default Mapepire port is 8076.
# -----------------------------------------------------------------------------
DB2i_HOST=YOUR_IBMI_HOSTNAME_OR_IP
DB2i_PORT=8076
DB2i_IGNORE_UNAUTHORIZED=true

# For development only — shared credentials (stdio/local mode).
# In production (HTTP mode + IBM i Auth) these are replaced by bearer tokens.
DB2i_USER=YOUR_IBMI_USERNAME
DB2i_PASS=YOUR_IBMI_PASSWORD

# -----------------------------------------------------------------------------
# MCP Server Transport
# Use "http" to expose the server over HTTP (required for watsonx Orchestrate).
# Use "stdio" for local development with Bob/Claude Desktop.
# -----------------------------------------------------------------------------
MCP_TRANSPORT_TYPE=http
MCP_HTTP_PORT=3010
MCP_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# IBM i HTTP Authentication (production — token-based, per-user)
# When enabled, DB2i_USER/DB2i_PASS above are NOT used at runtime.
# Each caller authenticates with their own IBM i credentials via RSA exchange.
# Generate RSA keys with: scripts/setup.sh --generate-keys
# -----------------------------------------------------------------------------
# MCP_AUTH_MODE=ibmi
# IBMI_HTTP_AUTH_ENABLED=true
# IBMI_AUTH_KEY_ID=production
# IBMI_AUTH_PRIVATE_KEY_PATH=secrets/private.pem
# IBMI_AUTH_PUBLIC_KEY_PATH=secrets/public.pem
# IBMI_AUTH_ALLOW_HTTP=true        # Set false when HTTPS is in place
# IBMI_AUTH_TOKEN_EXPIRY_SECONDS=3600

# -----------------------------------------------------------------------------
# SAMCO Retail Schema (used in tools/retail-services.yaml)
# -----------------------------------------------------------------------------
CLAI_SCHEMA=YOUR_LIBRARY_NAME
